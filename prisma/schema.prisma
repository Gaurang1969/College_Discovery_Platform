generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String         @id @default(cuid())
  email     String         @unique
  password  String
  createdAt DateTime       @default(now())
  saved     SavedCollege[]
}

model College {
  id          String         @id @default(cuid())
  name        String
  location    String
  fees        Int
  rating      Float
  courses     String[]
  overview    String
  placements  Json
  createdAt   DateTime       @default(now())
  saved       SavedCollege[]

  @@index([name])
  @@index([location])
  @@index([fees])
  @@index([rating])
}

model SavedCollege {
  id        String   @id @default(cuid())
  userId    String
  collegeId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  college   College  @relation(fields: [collegeId], references: [id])

  @@unique([userId, collegeId])
}